# Copy this file to .env and fill in your API keys.
# .env is gitignored and will NOT be committed.

DEEPSEEK_API_KEY=your-deepseek-api-key-here
NVIDIA_API_KEY=your-nvidia-api-key-here
WEB_SECONDARY_MODEL_API_KEY=your-deepseek-chat-api-key-here

# ── GitHub Personal Access Token (for git push) ──────────────────────────
# Classic PAT (ghp_xxx) or fine-grained PAT (github_pat_xxx).
# Scoped to the repos you want the agent to push to (repo scope for classic).
# Leave empty or omit to skip — agent can still pull public repos anonymously.
GITHUB_TOKEN=your-github-pat-here

# ── Web Access Password (for mobile-friendly web and security) ───────────
# Set this to enable password protection on all web API routes.
# When set, you must log in via the mobile web app (/m or /mobile/)
# before any API calls are allowed. Leave empty to disable auth.
# Change this regularly for better security.
ACCESS_PASSWORD=
